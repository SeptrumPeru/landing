---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  images: ImageMetadata[];
  name: string;
}

const { images, name } = Astro.props;
---

<div class="flex flex-col gap-2 md:gap-4 lg:gap-6" data-gallery>
  <div
    class="rounded-base relative aspect-square w-full overflow-hidden md:rounded-[36px]"
  >
    <div
      data-gallery-track
      class="no-scrollbar flex size-full snap-x snap-mandatory overflow-x-auto overscroll-x-contain scroll-smooth touch-pan-y"
    >
      {
        images.map((img, i) => (
          <div
            data-gallery-slide
            data-index={i}
            class="relative size-full flex-none snap-center snap-always"
          >
            <Image
              src={img}
              alt=""
              aria-hidden="true"
              width={900}
              class="absolute inset-0 size-full scale-110 object-cover blur-2xl"
            />
            <Image
              src={img}
              alt={`${name} — imagen ${i + 1} de ${images.length}`}
              width={900}
              class="relative size-full object-contain"
            />
          </div>
        ))
      }
    </div>

    {
      images.length > 1 && (
        <>
          <button
            type="button"
            data-gallery-prev
            aria-label="Imagen anterior"
            class="absolute top-1/2 left-6 hidden -translate-y-1/2 cursor-pointer items-center justify-center rounded-full bg-black p-2.5 text-white transition-colors sm:flex"
          >
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
              <path
                d="M3.50802 9.059H14.9738C15.2646 9.059 15.5083 8.95877 15.7051 8.7583C15.9017 8.55783 16 8.30944 16 8.01312C16 7.71681 15.9017 7.46637 15.7051 7.26181C15.5083 7.05725 15.2646 6.95498 14.9738 6.95498H3.50802L8.53362 1.80566C8.73878 1.59546 8.84135 1.34911 8.84135 1.06662C8.84135 0.784139 8.73678 0.531072 8.52763 0.307422C8.31848 0.102474 8.07606 0 7.80036 0C7.52466 0 7.28404 0.105396 7.0785 0.316189L0.296615 7.27379C0.19394 7.37919 0.118835 7.49335 0.0713015 7.61628C0.0237675 7.73921 0 7.87101 0 8.01166C0 8.15213 0.0237675 8.28392 0.0713015 8.40705C0.118835 8.52997 0.190137 8.64014 0.285206 8.73755L7.07308 15.6925C7.28223 15.9068 7.51991 16.0091 7.7861 15.9994C8.05229 15.9896 8.28996 15.8823 8.49911 15.6773C8.70826 15.4537 8.81283 15.199 8.81283 14.9132C8.81283 14.6276 8.70826 14.3808 8.49911 14.173L3.50802 9.059Z"
                fill="#FAFAFA"
              />
            </svg>
          </button>
          <button
            type="button"
            data-gallery-next
            aria-label="Imagen siguiente"
            class="absolute top-1/2 right-6 hidden -translate-y-1/2 cursor-pointer items-center justify-center rounded-full bg-black p-2.5 text-white transition-colors sm:flex"
          >
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
              <path
                d="M12.492 9.059H1.02617C0.735448 9.059 0.491693 8.95877 0.294902 8.7583C0.0983005 8.55783 0 8.30944 0 8.01312C0 7.71681 0.0983005 7.46637 0.294902 7.26181C0.491693 7.05725 0.735448 6.95498 1.02617 6.95498H12.492L7.46638 1.80566C7.26122 1.59546 7.15865 1.34911 7.15865 1.06662C7.15865 0.784139 7.26322 0.531072 7.47237 0.307422C7.68152 0.102474 7.92394 0 8.19964 0C8.47534 0 8.71596 0.105396 8.9215 0.316189L15.7034 7.27379C15.8061 7.37919 15.8812 7.49335 15.9287 7.61628C15.9762 7.73921 16 7.87101 16 8.01166C16 8.15213 15.9762 8.28392 15.9287 8.40705C15.8812 8.52997 15.8099 8.64014 15.7148 8.73755L8.92692 15.6925C8.71777 15.9068 8.48009 16.0091 8.2139 15.9994C7.94771 15.9896 7.71004 15.8823 7.50089 15.6773C7.29174 15.4537 7.18717 15.199 7.18717 14.9132C7.18717 14.6276 7.29174 14.3808 7.50089 14.173L12.492 9.059Z"
                fill="#FAFAFA"
              />
            </svg>
          </button>
        </>
      )
    }
  </div>

  {
    images.length > 1 && (
      <div class="flex gap-2 md:gap-4 lg:gap-6">
        {images.map((img, i) => (
          <button
            type="button"
            data-gallery-thumb
            data-index={i}
            aria-label={`Ver imagen ${i + 1}`}
            class:list={[
              "aspect-square flex-1 cursor-pointer overflow-hidden rounded-2xl border-2 transition-colors",
              i === 0 ? "border-green" : "border-border",
            ]}
          >
            <Image
              src={img}
              alt=""
              width={140}
              class="size-full object-cover"
            />
          </button>
        ))}
      </div>
    )
  }
</div>

<script>
  document
    .querySelectorAll<HTMLElement>("[data-gallery]")
    .forEach((gallery) => {
      const track = gallery.querySelector<HTMLElement>("[data-gallery-track]");
      const slides = gallery.querySelectorAll<HTMLElement>(
        "[data-gallery-slide]",
      );
      const thumbs = gallery.querySelectorAll<HTMLButtonElement>(
        "[data-gallery-thumb]",
      );
      const prevBtn = gallery.querySelector<HTMLButtonElement>(
        "[data-gallery-prev]",
      );
      const nextBtn = gallery.querySelector<HTMLButtonElement>(
        "[data-gallery-next]",
      );

      if (!track || slides.length <= 1) return;

      const prefersReducedMotion = window.matchMedia(
        "(prefers-reduced-motion: reduce)",
      ).matches;

      let active = 0;
      let autoplayTimer: ReturnType<typeof setInterval> | undefined;

      function stopAutoplay() {
        if (autoplayTimer === undefined) return;
        clearInterval(autoplayTimer);
        autoplayTimer = undefined;
      }

      function startAutoplay() {
        if (prefersReducedMotion) return;
        autoplayTimer = setInterval(() => {
          if (active >= slides.length - 1) {
            stopAutoplay();
            return;
          }
          goTo(active + 1);
        }, 5000);
      }

      function updateUI() {
        thumbs.forEach((thumb, i) => {
          thumb.classList.toggle("border-green", i === active);
          thumb.classList.toggle("border-border", i !== active);
        });

        if (prevBtn) prevBtn.style.display = active === 0 ? "none" : "";
        if (nextBtn) {
          nextBtn.style.display =
            active === slides.length - 1 ? "none" : "";
        }
      }

      // Native scroll-snap does the actual paging — this just commands it
      // and lets the scroll listener below reconcile `active` afterwards.
      function goTo(index: number) {
        active = Math.max(0, Math.min(index, slides.length - 1));
        track!.scrollTo({
          left: active * track!.clientWidth,
          behavior: prefersReducedMotion ? "auto" : "smooth",
        });
      }

      function manualGoTo(index: number) {
        stopAutoplay();
        goTo(index);
      }

      thumbs.forEach((thumb) => {
        thumb.addEventListener("click", () =>
          manualGoTo(Number(thumb.dataset.index)),
        );
      });

      prevBtn?.addEventListener("click", () => manualGoTo(active - 1));
      nextBtn?.addEventListener("click", () => manualGoTo(active + 1));

      // A direct touch/drag or wheel on the track is also a manual change —
      // cancel autoplay right away, before the native scroll even starts.
      track.addEventListener("pointerdown", stopAutoplay, { once: true });
      track.addEventListener("wheel", stopAutoplay, {
        once: true,
        passive: true,
      });

      let scrollRaf = 0;
      track.addEventListener(
        "scroll",
        () => {
          cancelAnimationFrame(scrollRaf);
          scrollRaf = requestAnimationFrame(() => {
            active = Math.round(track!.scrollLeft / track!.clientWidth);
            updateUI();
          });
        },
        { passive: true },
      );

      window.addEventListener("resize", () => {
        track!.scrollTo({ left: active * track!.clientWidth });
      });

      updateUI();
      startAutoplay();
    });
</script>
