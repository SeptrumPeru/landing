---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  category: {
    name: string;
    description: string;
    href: string;
    image: ImageMetadata;
  };
}

const { category } = Astro.props;
---

<a href={category.href} class="group flex flex-col gap-4 no-underline">
  <div class="rounded-base aspect-7/4 overflow-hidden">
    <Image
      src={category.image}
      alt={category.name}
      width={640}
      height={366}
      densities={[1, 2]}
      class="size-full object-cover transition-transform duration-500 ease-[cubic-bezier(0.16,1,0.3,1)] group-hover:scale-110"
    />
  </div>
  <div class="flex flex-col gap-2">
    <h3
      class="group-hover:text-green text-2xl font-medium tracking-tight text-black transition-colors duration-300"
    >
      {category.name}
    </h3>
    <p class="text-muted">{category.description}</p>
  </div>
</a>
