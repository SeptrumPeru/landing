---
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import { X } from "@lucide/astro";
import BaseLayout from "../layouts/base.astro";

import cta from "../images/productos/cta.jpg";
import { WHATSAPP_URL } from "../lib/constants";
import { categories, getCategoryByName } from "../lib/categories";
import Arrow from "../components/Arrow.astro";
import Product from "../components/Product.astro";

const productEntries = await getCollection("products");
const products = productEntries
  .map((entry) => ({
    slug: entry.id,
    name: entry.data.name,
    category: getCategoryByName(entry.data.category)!,
  }))
  .sort((a, b) => a.name.localeCompare(b.name));
---

<BaseLayout title="Septrum — Productos">
  <article class="px-6">
    <section
      class="mwx flex flex-col gap-8 pb-16 sm:gap-12 sm:pt-16 md:pt-24 md:pb-20"
    >
      <div
        class="flex flex-col gap-8 md:flex-row md:items-end md:justify-between"
      >
        <div class="flex flex-col gap-4 md:max-w-133.75 md:gap-7">
          <p class="text-green font-mono text-sm tracking-wider uppercase">
            Catálogo de productos
          </p>
          <h1
            class="text-[42px] leading-none tracking-tight text-balance text-black md:text-[64px]"
          >
            Equipos para el tratamiento de agua industrial
          </h1>
        </div>
        <p
          class="text-muted max-w-xl text-lg leading-relaxed font-light md:max-w-133.75 md:text-xl"
        >
          Explora por categoría. Cada equipo se cotiza a medida según el caudal,
          la calidad de agua y la normativa de tu proceso. <strong
            class="font-medium text-black">Solicita una cotización</strong
          > y un ingeniero te responderá.
        </p>
      </div>
    </section>

    <section class="mwx flex flex-col gap-8 pb-24 md:pb-32">
      <div class="flex flex-col gap-3">
        <div
          class="border-border flex w-full max-w-110 items-center gap-2 rounded-full border-2 px-4 pt-3 pb-2.5"
        >
          <svg
            width="20"
            height="20"
            viewBox="0 0 20 20"
            fill="none"
            class="shrink-0"
          >
            <path
              d="M8.00063 13C6.61132 13 5.43056 12.5139 4.45833 11.5417C3.48611 10.5694 3 9.38889 3 8C3 6.61111 3.48611 5.43056 4.45833 4.45833C5.43056 3.48611 6.61111 3 8 3C9.38889 3 10.5694 3.48611 11.5417 4.45833C12.5139 5.43056 13 6.61132 13 8.00063C13 8.5616 12.9132 9.09062 12.7396 9.58771C12.566 10.0848 12.3264 10.5417 12.0208 10.9583L16.4792 15.4167C16.6319 15.5694 16.7083 15.7431 16.7083 15.9375C16.7083 16.1319 16.6319 16.3056 16.4792 16.4583C16.3264 16.6111 16.1493 16.6875 15.9479 16.6875C15.7465 16.6875 15.5694 16.6111 15.4167 16.4583L10.9583 12.0208C10.5417 12.3264 10.0848 12.566 9.58771 12.7396C9.09062 12.9132 8.5616 13 8.00063 13ZM8 11.5C8.97222 11.5 9.79861 11.1597 10.4792 10.4792C11.1597 9.79861 11.5 8.97222 11.5 8C11.5 7.02778 11.1597 6.20139 10.4792 5.52083C9.79861 4.84028 8.97222 4.5 8 4.5C7.02778 4.5 6.20139 4.84028 5.52083 5.52083C4.84028 6.20139 4.5 7.02778 4.5 8C4.5 8.97222 4.84028 9.79861 5.52083 10.4792C6.20139 11.1597 7.02778 11.5 8 11.5Z"
              fill="var(--color-muted-dark)"></path>
          </svg>
          <input
            type="text"
            id="product-search"
            placeholder="Buscar..."
            autocomplete="off"
            class="placeholder:text-muted-dark w-full bg-transparent text-base leading-5 text-black outline-none"
          />
          <button
            type="button"
            id="clear-search"
            aria-label="Limpiar búsqueda"
            class="text-muted-dark hidden shrink-0 cursor-pointer"
          >
            <X size={20} />
          </button>
        </div>
        <div id="category-filters" class="flex flex-wrap gap-2.5">
          <button
            type="button"
            data-category-filter=""
            class="filter-pill filter-pill-active"
          >
            Todos
          </button>
          {
            categories.map((category) => (
              <button
                type="button"
                data-category-filter={category.slug}
                class="filter-pill"
              >
                {category.name}
              </button>
            ))
          }
        </div>
      </div>

      <p id="product-count" class="text-muted-dark">
        {products.length} equipos — todos se cotizan a medida
      </p>

      <div
        id="product-grid"
        class="grid grid-cols-1 gap-8 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4"
      >
        {products.map((product) => <Product {product} />)}
      </div>

      <p id="no-results" class="text-muted hidden py-16 text-center text-lg">
        No encontramos equipos que coincidan con tu búsqueda.
      </p>
    </section>
  </article>

  <article class="px-6">
    <section class="mwx pb-24 md:pb-32">
      <div
        data-reveal
        class="relative flex flex-col items-center gap-6 overflow-hidden rounded-4xl px-8 py-16 text-center md:items-start md:rounded-[48px] md:px-12 md:py-24 md:text-start"
      >
        <Image
          src={cta}
          alt="Planta de tratamiento de agua Septrum"
          width={1284}
          height={514}
          densities={[1, 2]}
          class="absolute inset-0 size-full object-cover saturate-0"
        />
        <div
          class="absolute inset-0 bg-linear-to-r from-black from-0% to-black/60 to-74% md:to-transparent"
        >
        </div>
        <h2
          class="relative max-w-xl text-[36px] leading-none text-balance text-white md:text-[64px]"
        >
          ¿No encuentras el equipo exacto?
        </h2>
        <p
          class="relative max-w-lg text-lg leading-relaxed font-light text-white md:text-xl"
        >
          Fabricamos a medida e importamos bajo pedido. Cuéntanos las
          especificaciones de tu proceso.
        </p>
        <a
          href={WHATSAPP_URL}
          target="_blank"
          rel="noreferrer noopener"
          class="btn relative bg-white text-black"
        >
          Solicita una cotización
          <div class="hidden md:block"><Arrow /></div>
        </a>
      </div>
    </section>
  </article>
</BaseLayout>

<script>
  const searchInput = document.getElementById(
    "product-search",
  ) as HTMLInputElement;
  const clearBtn = document.getElementById("clear-search") as HTMLButtonElement;
  const pills = document.querySelectorAll<HTMLButtonElement>(
    "[data-category-filter]",
  );
  const cards = document.querySelectorAll<HTMLElement>("[data-product-name]");
  const countEl = document.getElementById("product-count");
  const noResultsEl = document.getElementById("no-results");
  const grid = document.getElementById("product-grid");

  const params = new URLSearchParams(window.location.search);
  let activeCategory = params.get("category") ?? "";

  if (![...pills].some((p) => p.dataset.categoryFilter === activeCategory)) {
    activeCategory = "";
  }

  // Accent-insensitive, separator-insensitive matching — "uf 600" or
  // "caudalimetro" (no tilde) both match "Caudalímetro Ultrasónico UF-600".
  function normalize(value: string) {
    return value
      .toLowerCase()
      .replace(/[áàäâ]/g, "a")
      .replace(/[éèëê]/g, "e")
      .replace(/[íìïî]/g, "i")
      .replace(/[óòöô]/g, "o")
      .replace(/[úùüû]/g, "u")
      .replace(/ñ/g, "n")
      .replace(/[^a-z0-9]+/g, " ")
      .trim();
  }

  const normalizedNames = new Map<HTMLElement, string>();
  cards.forEach((card) => {
    normalizedNames.set(card, normalize(card.dataset.productName ?? ""));
  });

  function setActivePill() {
    pills.forEach((pill) => {
      const isActive = (pill.dataset.categoryFilter ?? "") === activeCategory;
      pill.classList.toggle("filter-pill-active", isActive);
    });
  }

  function applyFilters() {
    clearBtn.classList.toggle("hidden", searchInput.value.trim().length === 0);
    const queryTokens = normalize(searchInput.value).split(" ").filter(Boolean);

    let visibleCount = 0;

    cards.forEach((card) => {
      const matchesCategory =
        !activeCategory || card.dataset.productCategory === activeCategory;
      const name = normalizedNames.get(card) ?? "";
      const matchesQuery = queryTokens.every((token) => name.includes(token));
      const visible = matchesCategory && matchesQuery;
      card.classList.toggle("hidden", !visible);
      if (visible) visibleCount += 1;
    });

    if (countEl) {
      countEl.textContent =
        visibleCount === 1
          ? "1 equipo — todos se cotizan a medida"
          : `${visibleCount} equipos — todos se cotizan a medida`;
    }

    noResultsEl?.classList.toggle("hidden", visibleCount !== 0);
    grid?.classList.toggle("hidden", visibleCount === 0);
  }

  pills.forEach((pill) => {
    pill.addEventListener("click", () => {
      activeCategory = pill.dataset.categoryFilter ?? "";
      setActivePill();
      applyFilters();

      const url = new URL(window.location.href);
      if (activeCategory) {
        url.searchParams.set("category", activeCategory);
      } else {
        url.searchParams.delete("category");
      }
      window.history.replaceState({}, "", url);
    });
  });

  searchInput.addEventListener("input", applyFilters);
  clearBtn.addEventListener("click", () => {
    searchInput.value = "";
    applyFilters();
    searchInput.focus();
  });

  setActivePill();
  applyFilters();
</script>
