---
import { Image } from "astro:assets";

import BaseLayout from "../layouts/base.astro";
import { WHATSAPP_URL } from "../lib/constants";
import { categories } from "../lib/categories";

import heroPhoto from "../images/index/hero-photo.png";
import ctaBg from "../images/index/cta-bg.jpg";
import testimonialPhoto from "../images/index/testimonial-photo.png";

import Arrow from "../components/Arrow.astro";
import Category from "../components/Category.astro";

const motivos = [
  {
    number: "01",
    title: "Fabricación a medida",
    description:
      "Diseñamos y construimos skids, racks y equipos según las condiciones reales de tu proceso.",
  },
  {
    number: "02",
    title: "Importación directa",
    description:
      "Traemos marcas líderes con trazabilidad y certificación, sin intermediarios que encarezcan el equipo.",
  },
  {
    number: "03",
    title: "Soporte y mantenimiento",
    description:
      "Puesta en marcha, repuestos originales y respuesta técnica el mismo día en todo el país.",
  },
];

const testimonios = [
  {
    quote:
      "Septrum suministró el sistema UV completo para nuestra planta embotelladora. Instalación impecable y un soporte técnico que responde el mismo día.",
    role: "Jefe de Planta",
    company: "Industria de Bebidas — Arequipa",
  },
  {
    quote:
      "La precisión de sus caudalímetros y sensores nos permitió optimizar el consumo de agua en todo el proceso. Un socio técnico realmente confiable.",
    role: "Jefe de Planta",
    company: "Industria de Bebidas — Arequipa",
  },
  {
    quote:
      "Fabricaron e importaron a medida los repuestos que necesitábamos cuando nadie más los tenía en el país. Cumplieron los plazos al detalle.",
    role: "Jefe de Planta",
    company: "Industria de Bebidas — Arequipa",
  },
];
---

<BaseLayout title="Septrum — Filtros UV de agua industrial">
  <article class="px-6">
    <section
      class="mwx flex flex-col gap-8 pt-0 pb-16 md:flex-row-reverse md:items-center md:justify-between md:gap-12 md:pb-14"
    >
      <div
        class="relative mx-auto aspect-4/3 w-full shrink-0 md:mx-0 md:aspect-657/579 md:w-95 lg:w-125 xl:w-164.25"
      >
        <div
          class="absolute hidden items-center justify-center md:flex"
          style="left: 37.06%; top: 69.43%; width: 35.92%; height: 30.58%;"
        >
          <div
            class="animate-float-a -rotate-1 rounded-[28px] bg-black lg:rounded-[36px]"
            style="width: 98.74%; height: 97.72%;"
          >
          </div>
        </div>
        <div
          class="absolute hidden items-center justify-center md:flex"
          style="left: 48.39%; top: 0%; width: 51.61%; height: 92.55%;"
        >
          <div
            class="animate-float-b bg-green -rotate-2 rounded-[28px] lg:rounded-[36px]"
            style="width: 94.65%; height: 97.97%;"
          >
          </div>
        </div>
        <div
          class="absolute hidden items-center justify-center md:flex"
          style="left: 5.94%; top: 14.34%; width: 66.99%; height: 63.86%;"
        >
          <div
            class="animate-float-c bg-lime rotate-2 rounded-[28px] lg:rounded-[36px]"
            style="width: 97.24%; height: 96.02%;"
          >
          </div>
        </div>
        <div
          class="absolute inset-0 flex items-center justify-center md:inset-auto md:top-[20.39%] md:left-0 md:h-[63.86%] md:w-[66.99%]"
        >
          <div
            class="md:animate-float-d rounded-base h-full w-full overflow-hidden md:h-[96.02%] md:w-[97.24%] md:rotate-2 lg:rounded-[36px]"
          >
            <Image
              src={heroPhoto}
              alt="Equipo de tratamiento UV Septrum instalado en planta industrial"
              width={1467 / 2}
              densities={[1, 2]}
              class="size-full object-cover"
            />
          </div>
        </div>
      </div>
      <div class="flex flex-col gap-4 md:max-w-xl md:gap-7">
        <p class="text-green font-mono text-sm tracking-wider uppercase">
          Tratamiento de aguas industriales — Arequipa, Perú
        </p>
        <h1
          class="max-w-xl text-[42px] leading-none tracking-tight text-balance text-black md:text-[64px]"
        >
          Filtros <strong class="text-green font-semibold"><em>UV</em></strong> de
          agua para tu empresa
        </h1>
        <p
          class="text-muted max-w-xl text-lg leading-relaxed font-light md:text-xl"
        >
          Fabricamos e importamos <strong class="font-medium text-black"
            >sensores, medición de flujo, sistemas UV, filtración y válvulas</strong
          > de grado industrial. Equipos certificados para el tratamiento de aguas
          en tu proceso.
        </p>
        <div class="flex flex-col gap-2 md:flex-row md:items-center">
          <a href="/productos" class="btn btn-accent">
            Ver productos
            <Arrow />
          </a>
          <a
            href={WHATSAPP_URL}
            target="_blank"
            rel="noreferrer noopener"
            class="btn btn-secondary">Contáctanos</a
          >
        </div>
      </div>
    </section>

    <section class="mwx pb-16 md:pb-24">
      <div
        data-reveal
        class="bg-lime rounded-base flex flex-col gap-8 px-8 py-10 text-black md:flex-row md:items-center md:justify-between md:rounded-[48px] md:px-12 md:py-16"
      >
        <p
          class="max-w-xl text-end text-[36px] leading-none text-balance md:text-start md:text-[48px]"
        >
          Fabricamos e importamos productos de calidad
        </p>
        <div
          class="grid grid-cols-2 justify-items-center gap-0 whitespace-nowrap md:flex md:gap-12"
        >
          <div class="flex flex-col items-center">
            <span
              class="font-mono text-[40px] leading-none md:text-[60px]"
              data-count-to="35"
              data-prefix="+">0</span
            >
            <span class="mt-1 text-lg md:text-2xl">Productos</span>
          </div>
          <div class="flex flex-col items-center">
            <span
              class="font-mono text-[40px] leading-none md:text-[60px]"
              data-count-to="2022">0</span
            >
            <span class="mt-1 text-lg md:text-2xl">Desde el año</span>
          </div>
        </div>
      </div>
    </section>

    <section class="mwx flex flex-col gap-12 pb-24 md:gap-12 md:pb-32">
      <div
        data-reveal
        class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between"
      >
        <div class="flex flex-col gap-5 md:max-w-xl md:gap-7">
          <p class="text-green font-mono text-sm tracking-wider uppercase">
            Catálogo
          </p>
          <h2
            class="text-[32px] leading-none tracking-tight text-balance text-black md:text-[48px]"
          >
            Seis líneas de producto, una sola fuente confiable
          </h2>
        </div>
        <a href="/productos" class="btn btn-primary shrink-0">
          Nuestro catálogo
          <Arrow />
        </a>
      </div>

      <div
        class="grid grid-cols-1 gap-x-8 gap-y-10 sm:grid-cols-2 md:grid-cols-3"
      >
        {
          categories.map((category, i) => (
            <div data-reveal style={{ "--i": i % 3 }}>
              <Category
                category={{
                  ...category,
                  href: `/productos?category=${category.slug}`,
                }}
              />
            </div>
          ))
        }
      </div>
    </section>
  </article>

  <section class="bg-black px-6 py-20 md:py-28">
    <div
      class="mwx flex flex-col gap-16 md:flex-row md:items-center md:justify-between md:gap-12"
    >
      <div data-reveal class="flex flex-col gap-5 md:max-w-xl md:gap-7">
        <p class="text-lime font-mono text-sm tracking-wider uppercase">
          Por qué Septrum
        </p>
        <h2
          class="text-[32px] leading-none tracking-tight text-balance text-white md:text-[48px]"
        >
          Fabricación e importación bajo un mismo techo
        </h2>
        <p
          class="text-muted-dark max-w-xl text-lg leading-relaxed font-light md:text-xl"
        >
          Desde Arequipa atendemos plantas industriales en todo el Perú.
          Combinamos fabricación local a medida con la importación directa de
          marcas líderes, garantizando equipos certificados y respaldo técnico
          permanente.
        </p>
        <a href="/nosotros" class="btn btn-accent self-start">
          Conoce a la empresa
          <Arrow />
        </a>
      </div>

      <div class="flex flex-col gap-6 md:max-w-lg">
        {
          motivos.map((motivo, i) => (
            <>
              <div
                data-reveal
                style={{ "--i": i }}
                class="flex items-center gap-4"
              >
                <span class="text-lime font-mono text-sm tracking-wider uppercase">
                  {motivo.number}
                </span>
                <div class="flex flex-col gap-1.5">
                  <h3 class="text-xl text-white">{motivo.title}</h3>
                  <p class="text-muted-dark font-light">{motivo.description}</p>
                </div>
              </div>
              {i < motivos.length - 1 && (
                <div class="border-border-dark border-t" />
              )}
            </>
          ))
        }
      </div>
    </div>
  </section>

  <article id="testimonios" class="px-6">
    <section class="mwx flex flex-col gap-12 pt-24 pb-24 md:pt-32 md:pb-32">
      <div data-reveal class="flex flex-col gap-5 md:max-w-xl md:gap-7">
        <p class="text-green font-mono text-sm tracking-wider uppercase">
          Clientes
        </p>
        <h2
          class="text-[32px] leading-none tracking-tight text-balance text-black md:text-[48px]"
        >
          Plantas industriales que confían en Septrum
        </h2>
      </div>

      <div class="flex flex-col items-stretch gap-8 lg:flex-row">
        <div class="flex flex-col gap-8 lg:w-2/3">
          <div class="grid grid-cols-1 gap-8 md:grid-cols-2">
            {
              testimonios.slice(0, 2).map((t, i) => (
                <div
                  data-reveal
                  style={{ "--i": i }}
                  class="bg-green flex flex-col justify-between gap-8 rounded-[36px] p-8"
                >
                  <div class="flex flex-col gap-6">
                    <svg
                      viewBox="0 0 69 51"
                      fill="none"
                      class="h-9.5 w-12.75 text-white"
                      xmlns="http://www.w3.org/2000/svg"
                    >
                      <path
                        d="M69 7.7117L58.8621 22.3125C61.4138 23.1351 63.6207 24.7803 65.4828 27.248C67.4138 29.6472 68.3793 32.5262 68.3793 35.8851C68.3793 40.2036 66.931 43.8024 64.0345 46.6815C61.1379 49.5605 57.4138 51 52.8621 51C48.4483 51 44.7586 49.5605 41.7931 46.6815C38.8966 43.8024 37.4483 40.2036 37.4483 35.8851C37.4483 33.3488 37.931 30.8811 38.8966 28.4819C39.931 26.0827 41.6897 23.0665 44.1724 19.4335L57.5172 0C57.5172 0 61.3448 2.57057 69 7.7117ZM31.5517 7.7117L21.4138 22.3125C23.8966 23.1351 26.1034 24.7803 28.0345 27.248C29.9655 29.6472 30.931 32.5262 30.931 35.8851C30.931 40.2036 29.4828 43.8024 26.5862 46.6815C23.6897 49.5605 19.9655 51 15.4138 51C10.931 51 7.24138 49.5605 4.34483 46.6815C1.44828 43.8024 0 40.2036 0 35.8851C0 33.3488 0.482759 30.8811 1.44828 28.4819C2.48276 26.0827 4.24138 23.0665 6.72414 19.4335L20.069 0C20.069 0 23.8966 2.57057 31.5517 7.7117Z"
                        fill="currentColor"
                      />
                    </svg>
                    <p class="text-white md:text-lg">“{t.quote}”</p>
                  </div>
                  <div class="flex flex-col">
                    <p class="font-medium text-white">{t.role}</p>
                    <p class="text-border text-sm font-light">{t.company}</p>
                  </div>
                </div>
              ))
            }
          </div>

          <div
            data-reveal
            style={{ "--i": 2 }}
            class="bg-green flex flex-col gap-6 rounded-[36px] p-8"
          >
            <svg
              viewBox="0 0 69 51"
              fill="none"
              class="h-9.5 w-12.75 text-white"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path
                d="M69 7.7117L58.8621 22.3125C61.4138 23.1351 63.6207 24.7803 65.4828 27.248C67.4138 29.6472 68.3793 32.5262 68.3793 35.8851C68.3793 40.2036 66.931 43.8024 64.0345 46.6815C61.1379 49.5605 57.4138 51 52.8621 51C48.4483 51 44.7586 49.5605 41.7931 46.6815C38.8966 43.8024 37.4483 40.2036 37.4483 35.8851C37.4483 33.3488 37.931 30.8811 38.8966 28.4819C39.931 26.0827 41.6897 23.0665 44.1724 19.4335L57.5172 0C57.5172 0 61.3448 2.57057 69 7.7117ZM31.5517 7.7117L21.4138 22.3125C23.8966 23.1351 26.1034 24.7803 28.0345 27.248C29.9655 29.6472 30.931 32.5262 30.931 35.8851C30.931 40.2036 29.4828 43.8024 26.5862 46.6815C23.6897 49.5605 19.9655 51 15.4138 51C10.931 51 7.24138 49.5605 4.34483 46.6815C1.44828 43.8024 0 40.2036 0 35.8851C0 33.3488 0.482759 30.8811 1.44828 28.4819C2.48276 26.0827 4.24138 23.0665 6.72414 19.4335L20.069 0C20.069 0 23.8966 2.57057 31.5517 7.7117Z"
                fill="currentColor"></path>
            </svg>
            <p class="text-white md:text-lg">“{testimonios[2].quote}”</p>
            <div class="flex flex-col">
              <p class="font-medium text-white">{testimonios[2].role}</p>
              <p class="text-border text-sm font-light">
                {testimonios[2].company}
              </p>
            </div>
          </div>
        </div>

        <div
          data-reveal
          class="relative hidden overflow-hidden rounded-[36px] lg:block lg:w-1/3"
        >
          <Image
            src={testimonialPhoto}
            alt="Fachada de planta industrial cliente de Septrum"
            width={389}
            height={432}
            densities={[1, 2]}
            data-parallax
            class="absolute inset-x-0 top-[-15%] h-[130%] w-full object-cover"
          />
        </div>
      </div>
    </section>

    <section class="mwx pb-24 md:pb-32">
      <div
        data-reveal
        class="relative flex flex-col items-center gap-6 overflow-hidden rounded-4xl px-8 py-16 text-center md:items-start md:rounded-[48px] md:px-12 md:py-24 md:text-start"
      >
        <Image
          src={ctaBg}
          alt="Planta de tratamiento de agua Septrum"
          width={1284}
          height={514}
          densities={[1, 2]}
          class="absolute inset-0 size-full object-cover"
        />
        <div
          class="absolute inset-0 bg-linear-to-r from-black from-0% to-black/30 to-74% md:to-transparent"
        >
        </div>
        <h2
          class="relative max-w-xl text-[36px] leading-none text-balance text-white md:text-[64px]"
        >
          ¿Listo para optimizar el agua de tu planta?
        </h2>
        <p
          class="relative max-w-lg text-lg leading-relaxed font-light text-white md:text-xl"
        >
          Cuéntanos sobre tu proceso y nuestro equipo técnico preparará una
          cotización a la medida de tu operación.
        </p>
        <a
          href={WHATSAPP_URL}
          target="_blank"
          rel="noreferrer noopener"
          class="btn relative bg-white text-black"
        >
          Solicita una cotización
          <div class="hidden md:block"><Arrow /></div>
        </a>
      </div>
    </section>
  </article>
</BaseLayout>

<script>
  const prefersReducedMotion = window.matchMedia(
    "(prefers-reduced-motion: reduce)",
  ).matches;

  function animateCount(el: HTMLElement) {
    const target = parseInt(el.dataset.countTo ?? "0", 10);
    const prefix = el.dataset.prefix ?? "";

    if (prefersReducedMotion) {
      el.textContent = prefix + target;
      return;
    }

    const duration = 1200;
    const start = performance.now();

    function tick(now: number) {
      const progress = Math.min((now - start) / duration, 1);
      const eased = 1 - Math.pow(1 - progress, 3);
      el.textContent = prefix + Math.round(target * eased);
      if (progress < 1) requestAnimationFrame(tick);
    }

    requestAnimationFrame(tick);
  }

  const countObserver = new IntersectionObserver(
    (entries) => {
      for (const entry of entries) {
        if (!entry.isIntersecting) continue;
        animateCount(entry.target as HTMLElement);
        countObserver.unobserve(entry.target);
      }
    },
    { threshold: 0.6 },
  );

  document
    .querySelectorAll<HTMLElement>("[data-count-to]")
    .forEach((el) => countObserver.observe(el));

  // Parallax — the testimonial photo drifts opposite to scroll so it reads
  // with a bit of depth against the cards beside it.
  const parallaxEls = document.querySelectorAll<HTMLElement>("[data-parallax]");

  if (parallaxEls.length && !prefersReducedMotion) {
    let ticking = false;

    function updateParallax() {
      const viewportH = window.innerHeight;
      parallaxEls.forEach((el) => {
        const parent = el.parentElement;
        if (!parent) return;
        const rect = parent.getBoundingClientRect();
        const centerOffset = rect.top + rect.height / 2 - viewportH / 2;
        const shift = Math.max(-70, Math.min(70, centerOffset * -0.15));
        el.style.transform = `translateY(${shift}px)`;
      });
      ticking = false;
    }

    function onScroll() {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(updateParallax);
    }

    window.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("resize", onScroll);
    updateParallax();
  }
</script>
