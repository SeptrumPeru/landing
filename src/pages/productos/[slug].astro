---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/base.astro";
import { getCategoryByName } from "../../lib/categories";
import { getProductQuoteUrl, getProductDatasheetUrl } from "../../lib/constants";
import Arrow from "../../components/Arrow.astro";
import Product from "../../components/Product.astro";
import ProductGallery from "../../components/ProductGallery.astro";
import SpecsTable from "../../components/SpecsTable.astro";

export async function getStaticPaths() {
  const entries = await getCollection("products");
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const category = getCategoryByName(entry.data.category)!;
const images = entry.data.images?.length ? entry.data.images : [category.image];

const allProducts = await getCollection("products");
const related = allProducts
  .filter((p) => p.id !== entry.id && p.data.category === entry.data.category)
  .slice(0, 4)
  .map((p) => ({
    slug: p.id,
    name: p.data.name,
    category: getCategoryByName(p.data.category)!,
  }));
---

<BaseLayout title={`Septrum — ${entry.data.name}`}>
  <article class="px-6">
    <nav
      aria-label="Ruta de navegación"
      class="mwx text-muted-dark flex items-center gap-3 pt-24 pb-8 font-mono text-sm tracking-wider uppercase md:pt-16"
    >
      <a href="/productos" class="text-green no-underline">Catálogo de productos</a>
      <span>/</span>
      <a
        href={`/productos?category=${category.slug}`}
        class="text-green no-underline"
      >
        {category.name}
      </a>
      <span>/</span>
      <span class="text-muted truncate">{entry.id}</span>
    </nav>

    <section class="mwx flex flex-col gap-8 pb-24 md:flex-row md:gap-12 md:pb-32 lg:gap-24">
      <div class="md:flex-1">
        <ProductGallery images={images} name={entry.data.name} />
      </div>

      <div class="flex flex-col gap-6 md:flex-1">
        <p class="text-green font-mono text-sm tracking-wider uppercase">
          {category.name}
        </p>
        <h1
          class="text-[36px] leading-none font-semibold tracking-tight text-balance text-black md:text-[48px] lg:text-[64px]"
        >
          {entry.data.name}
        </h1>
        {
          entry.data.description && (
            <p class="text-muted text-lg leading-relaxed font-light">
              {entry.data.description}
            </p>
          )
        }

        <SpecsTable specs={entry.data.specs ?? []} />

        <div class="flex flex-col gap-2 sm:flex-row sm:items-center">
          <a
            href={getProductQuoteUrl(entry.data.name)}
            target="_blank"
            rel="noreferrer noopener"
            class="btn btn-accent gap-2"
          >
            Solicitar cotización
            <Arrow />
          </a>
          <a
            href={getProductDatasheetUrl(entry.data.name)}
            target="_blank"
            rel="noreferrer noopener"
            class="btn btn-secondary"
          >
            Ficha técnica
          </a>
        </div>
      </div>
    </section>

    {
      related.length > 0 && (
        <section class="mwx flex flex-col gap-12 pb-24 md:pb-32">
          <div class="flex items-end justify-between gap-4">
            <h2 class="text-[32px] leading-none tracking-tight text-balance text-black md:text-[48px]">
              Productos relacionados
            </h2>
            <a
              href={`/productos?category=${category.slug}`}
              class="btn btn-primary hidden shrink-0 gap-2 sm:flex"
            >
              Ver todos
              <Arrow />
            </a>
          </div>

          <div class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-4">
            {related.map((product) => (
              <Product product={product} />
            ))}
          </div>
        </section>
      )
    }
  </article>
</BaseLayout>
