---
import { getCollection } from "astro:content";
import { getImage } from "astro:assets";
import BaseLayout from "../../layouts/base.astro";
import { getCategoryByName } from "../../lib/categories";
import {
  getProductQuoteUrl,
  getProductDatasheetUrl,
} from "../../lib/constants";
import Arrow from "../../components/Arrow.astro";
import Product from "../../components/Product.astro";
import ProductGallery from "../../components/ProductGallery.astro";
import SpecsTable from "../../components/SpecsTable.astro";
import { Download } from "@lucide/astro";

export async function getStaticPaths() {
  const entries = await getCollection("products");
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const category = getCategoryByName(entry.data.category)!;
const images = entry.data.images?.length ? entry.data.images : [category.image];

const allProducts = await getCollection("products");
const related = allProducts
  .filter((p) => p.id !== entry.id && p.data.category === entry.data.category)
  .slice(0, 4)
  .map((p) => ({
    slug: p.id,
    name: p.data.name,
    category: getCategoryByName(p.data.category)!,
  }));

const description =
  entry.data.description ??
  `${entry.data.name} — ${category.name}. Equipo cotizado a medida por Septrum.`;

const optimizedGalleryImages = await Promise.all(
  images.map((img) =>
    getImage({ src: img, width: 1200, height: 1200, format: "jpg" }),
  ),
);
const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: entry.data.name,
  description,
  category: category.name,
  image: optimizedGalleryImages.map((img) =>
    new URL(img.src, Astro.site).toString(),
  ),
  brand: { "@type": "Brand", name: "Septrum" },
};
---

<BaseLayout
  title={`Septrum — ${entry.data.name}`}
  description={description}
  image={images[0]}
  type="product"
  structuredData={productSchema}
>
  <article class="px-6">
    <nav
      aria-label="Ruta de navegación"
      class="mwx text-border flex flex-wrap items-center gap-3 pb-8 font-mono text-sm tracking-wider uppercase"
    >
      <a
        href="/productos"
        class="text-muted-dark hover:text-green no-underline transition-colors"
        >Catálogo de productos</a
      >
      <span>/</span>
      <a
        href={`/productos?category=${category.slug}`}
        class="text-muted-dark hover:text-green no-underline transition-colors"
      >
        {category.name}
      </a>
      <span>/</span>
      <span class="truncate text-black">{entry.id}</span>
    </nav>

    <section
      class="mwx flex flex-col gap-8 pb-24 md:flex-row md:gap-12 md:pb-32 lg:gap-24"
    >
      <div class="md:flex-1">
        <ProductGallery images={images} name={entry.data.name} />
      </div>

      <div class="flex flex-col gap-6 md:flex-1">
        <p class="text-green font-mono text-sm tracking-wider uppercase">
          {category.name}
        </p>
        <h1
          class="text-[36px] leading-none font-medium tracking-tight text-balance text-black md:text-[48px] lg:text-[64px]"
        >
          {entry.data.name}
        </h1>
        {
          entry.data.description && (
            <p class="text-muted text-lg leading-relaxed font-light">
              {entry.data.description}
            </p>
          )
        }

        <SpecsTable specs={entry.data.specs ?? []} />

        <div class="flex flex-col gap-2 sm:flex-row sm:items-center">
          <a
            href={getProductQuoteUrl(entry.data.name)}
            target="_blank"
            rel="noreferrer noopener"
            class="btn btn-accent"
          >
            Solicitar cotización
            <Arrow />
          </a>
          <a
            href={getProductDatasheetUrl(entry.data.name)}
            target="_blank"
            rel="noreferrer noopener"
            class="btn btn-secondary"
          >
            <Download size={16} stroke-width={2.5} />
            Ficha técnica
          </a>
        </div>
      </div>
    </section>

    {
      related.length > 0 && (
        <section class="mwx flex flex-col gap-12 pb-24 md:pb-32">
          <div class="flex items-end justify-between gap-4">
            <h2 class="text-[32px] leading-none tracking-tight text-balance text-black md:text-[48px]">
              Productos relacionados
            </h2>
            <a
              href={`/productos?category=${category.slug}`}
              class="btn btn-primary hidden shrink-0 sm:flex"
            >
              Ver todos
              <Arrow />
            </a>
          </div>

          <div class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-4">
            {related.map((product) => (
              <Product product={product} />
            ))}
          </div>
        </section>
      )
    }
  </article>
</BaseLayout>
